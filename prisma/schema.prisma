generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Conexão "pooled" da Supabase (PgBouncer, porta 6543) — usada pelo app na Vercel.
  url       = env("DATABASE_URL")
  // Conexão direta (porta 5432) — usada apenas para migrations/db push.
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER // colaborador comum
  RECEPTION // recepção: acompanha agendas
  IT_ADMIN // TI: administra tudo
  DIRECTOR // diretoria: aprova salas restritas
}

enum BookingStatus {
  PENDING // aguardando aprovação
  CONFIRMED // confirmada (convites enviados)
  REJECTED // recusada pela diretoria/TI
  CANCELLED // cancelada pelo organizador/admin
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  bookings Booking[] @relation("organizer")
  decided  Booking[] @relation("decider")
}

model Booking {
  id          String        @id @default(cuid())
  title       String
  description String?
  start       DateTime
  end         DateTime
  status      BookingStatus @default(CONFIRMED)
  createdAt   DateTime      @default(now())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  organizerId String
  organizer   User   @relation("organizer", fields: [organizerId], references: [id])

  // quem decidiu a aprovação (diretoria/TI)
  decidedById  String?
  decidedBy    User?     @relation("decider", fields: [decidedById], references: [id])
  decidedAt    DateTime?
  decisionNote String?

  attendees Attendee[]

  // Integração com Microsoft Graph (evento de calendário + Teams)
  calendarEventId String?
  teamsJoinUrl    String?

  @@index([roomId, start, end])
  @@index([status])
}

model Attendee {
  id        String  @id @default(cuid())
  email     String
  name      String?
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Room {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  location        String?
  capacity        Int       @default(4)
  description     String?
  color           String    @default("#FB0047")
  requiresApproval Boolean  @default(false)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  bookings Booking[]
}

// Catálogo de contatos para o autocomplete (externos digitados ficam gravados aqui).
model Contact {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  external  Boolean  @default(true) // true = fora do tenant
  createdAt DateTime @default(now())

  @@index([name])
}

// ---- Auth.js (NextAuth) ----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
