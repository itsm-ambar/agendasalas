# ════════════════════════════════════════════════════════════════
#  AgendaSalas — variáveis de ambiente
#  Stack: GitHub → Vercel → Supabase (Postgres)
# ════════════════════════════════════════════════════════════════

# ── Banco de dados ──────────────────────────────────────────────
# OPÇÃO A) Supabase (nuvem, sem instalar nada):
#   Project Settings → Database → Connection string
#   DATABASE_URL = "Transaction pooler" (porta 6543) + ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = "Direct connection"  (porta 5432)
DATABASE_URL="postgresql://postgres.PROJ:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJ:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"
#
# OPÇÃO B) Postgres local via Docker (100% offline). Rode:
#   docker run --name agenda-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
# e use AS DUAS iguais:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ── Auth.js (NextAuth) ──────────────────────────────────────────
# Gere com:  npx auth secret   (ou: openssl rand -base64 32)
AUTH_SECRET="troque-por-um-valor-aleatorio-forte"
AUTH_URL="http://localhost:3000"

# ── LOGIN DE DESENVOLVIMENTO (só local!) ────────────────────────
# Com isto = "true" aparece um login por e-mail (sem senha) na tela /login,
# pra você testar layout e fluxo SEM configurar o Azure.
# Nunca funciona quando NODE_ENV=production.
ENABLE_DEV_LOGIN="true"

# ── Microsoft Entra ID (produção) — pode deixar vazio no teste local ─
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"

# ── Quem entra como TI/Admin (separe por vírgula) ───────────────
# No teste local, use ESTE e-mail no dev-login para virar Admin.
ADMIN_EMAILS="voce@autodoc.com.br"

# ── Convites (.ics) por e-mail — opcional ───────────────────────
# Sem RESEND_API_KEY o app funciona; convites só aparecem no log do terminal.
RESEND_API_KEY=""
EMAIL_FROM="AgendaSalas <agenda@autodoc.com.br>"
APP_TIMEZONE="America/Sao_Paulo"
